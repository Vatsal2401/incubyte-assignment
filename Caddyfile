# Caddy auto-provisions and renews HTTPS (Let's Encrypt) for the subdomain,
# then routes API calls to the NestJS service and everything else to the SPA.
{
	email niraj@autoreels.in
}

incubyte-assignment.autoreels.in {
	encode gzip zstd

	handle /api/* {
		reverse_proxy api:3000
	}

	handle {
		reverse_proxy web:80
	}
}
