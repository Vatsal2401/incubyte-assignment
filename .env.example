# Copy to apps/api/.env and adjust. Never commit the real .env.

# Prisma datasource. SQLite by default (Postgres-portable schema).
# To switch to Postgres later: change the provider in schema.prisma and this URL.
DATABASE_URL="file:./dev.db"

# API server
PORT=3000

# Web app (Vite) — base URL of the API
VITE_API_BASE_URL="http://localhost:3000"
